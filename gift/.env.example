# Alf-E — environment configuration
#
# The installer script fills most of this in for you.
# You only need to paste TWO values below:
#   1. ANTHROPIC_API_KEY — from https://console.anthropic.com
#   2. HA_API_TOKEN      — from Home Assistant → Profile → Security → Long-Lived Access Tokens

# ── Required: paste these two ─────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_ME
HA_API_TOKEN=REPLACE_ME

# ── Auto-generated by installer — do not edit ─────────────────────────────
ALFE_API_TOKEN=WILL_BE_GENERATED

# ── Optional: change only if HA runs on a different machine ───────────────
# Default works when HA runs on the same computer as Alf-E.
HA_URL=http://host.docker.internal:8123

# ── Optional: which playbook to load ──────────────────────────────────────
# Leave as-is unless you've been given a custom playbook.
ALFE_PLAYBOOK=playbooks/example_household.toml
