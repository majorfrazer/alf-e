# Alf-E — Scholz Brotherhood Edition
# Copy this file to .env and fill in the values below.

# ── Required ────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com (sign in, then API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Home Assistant Long-Lived Access Token
# Create in HA: Profile → Security → Long-Lived Access Tokens → Create
HA_API_TOKEN=

# The PWA login token — pick any long random string.
# Generate one with: openssl rand -base64 32
ALFE_API_TOKEN=

# ── Optional ────────────────────────────────────────────────────────────
# HA URL — default assumes HA on the same mac mini.
# Leave as-is unless HA runs elsewhere on the network.
HA_URL=http://host.docker.internal:8123
