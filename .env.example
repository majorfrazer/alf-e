# Alf-E Environment Variables — copy to .env and fill in values
# Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: AI providers ────────────────────────────────────────────────────
GOOGLE_API_KEY=AIza...          # Gemini Flash for "fast" tier routing

# ── Home Assistant ────────────────────────────────────────────────────────────
HA_API_TOKEN=...                # Long-lived token from HA → Profile → Security
# HA_URL defaults to http://homeassistant:8123 in docker-compose

# ── Gmail connector ───────────────────────────────────────────────────────────
# Token files are placed in the Docker volume at /data/
# Run scripts/gmail_auth.py on your Mac to generate them, then:
#   docker cp gmail_token.json alf-e:/data/gmail_token.json
#   docker cp gmail_credentials.json alf-e:/data/gmail_credentials.json

# ── Backblaze B2 (optional — cloud backup before connector commits) ────────────
B2_BUCKET=                      # e.g. alfe-backups
B2_PREFIX=alfe-backups
RCLONE_REMOTE=b2                # rclone remote name (configure with: rclone config)

# ── Tailscale ─────────────────────────────────────────────────────────────────
TAILSCALE_AUTHKEY=tskey-auth-... # One-time auth key from tailscale.com/admin/settings/keys

# ── Playbook ──────────────────────────────────────────────────────────────────
ALFE_PLAYBOOK=playbooks/cole_sandbox.toml
